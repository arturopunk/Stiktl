{
  "hosting": {
    "site": "stiktl",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "redirects": [
      {
        "source": "/download",
        "destination": "https://github.com/arturopunk/Stiktl/releases/download/v1.0/Stiktl.apk",
        "type": 302
      },
      {
        "source": "/Stiktl.apk",
        "destination": "https://github.com/arturopunk/Stiktl/releases/download/v1.0/Stiktl.apk",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.apk",
        "headers": [
          { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
          { "key": "Content-Disposition", "value": "attachment; filename=\"Stiktl.apk\"" }
        ]
      },
      {
        "source": "**/*.@(js|css|png)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ]
  }
}
